{
  "name": "devpilot-tool",
  "displayName": "Devpilot Tool",
  "description": "Repo-aware VS Code assistant for chat, analysis, refactoring suggestions, and inline productivity.",
  "version": "0.1.25",
  "publisher": "internal-tools",
  "license": "MIT",
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.95.0"
  },
  "keywords": [
    "devpilot",
    "assistant",
    "chat",
    "inline-completion",
    "developer-tools"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/dhananjay09892/vscode-tools-dhananjay-patel.git"
  },
  "bugs": {
    "url": "https://github.com/dhananjay09892/vscode-tools-dhananjay-patel/issues"
  },
  "homepage": "https://github.com/dhananjay09892/vscode-tools-dhananjay-patel",
  "preview": true,
  "files": [
    "out",
    "resources",
    "package.json",
    "README.md",
    "CHANGELOG.md",
    "docs",
    "LICENSE"
  ],
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:devpilot.openChat",
    "onCommand:devpilot.quickActions",
    "onCommand:devpilot.toggleInlineSuggestions",
    "onCommand:devpilot.openSettings",
    "onCommand:devpilot.configureTools",
    "onCommand:devpilot.attachFiles",
    "onView:devpilot.chatView",
    "onCommand:devpilot.configureLlm",
    "onCommand:devpilot.analyzeCurrentFile",
    "onCommand:devpilot.explainSelection",
    "onCommand:devpilot.generateTests",
    "onCommand:devpilot.refactorSuggestion"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "devpilot",
          "title": "Devpilot",
          "icon": "resources/icon.png"
        }
      ]
    },
    "views": {
      "devpilot": [
        {
          "id": "devpilot.chatView",
          "name": "Chat",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "devpilot.openChat",
        "title": "Devpilot: Open Chat"
      },
      {
        "command": "devpilot.quickActions",
        "title": "Devpilot: Quick Actions"
      },
      {
        "command": "devpilot.toggleInlineSuggestions",
        "title": "Devpilot: Toggle Inline Suggestions"
      },
      {
        "command": "devpilot.openSettings",
        "title": "Devpilot: Open Settings"
      },
      {
        "command": "devpilot.configureTools",
        "title": "Devpilot: Configure Tools"
      },
      {
        "command": "devpilot.attachFiles",
        "title": "Devpilot: Attach Files"
      },
      {
        "command": "devpilot.configureLlm",
        "title": "Devpilot: Configure LLM"
      },
      {
        "command": "devpilot.analyzeCurrentFile",
        "title": "Devpilot: Analyze Current File"
      },
      {
        "command": "devpilot.explainSelection",
        "title": "Devpilot: Explain Selection"
      },
      {
        "command": "devpilot.generateTests",
        "title": "Devpilot: Generate Tests"
      },
      {
        "command": "devpilot.refactorSuggestion",
        "title": "Devpilot: Refactor Suggestion"
      }
    ],
    "configuration": {
      "title": "Devpilot",
      "properties": {
        "devpilot.model": {
          "type": "string",
          "default": "devpilot-local-backend-v1",
          "description": "Model identifier shown in logs/output and optionally used by backend integrations."
        },
        "devpilot.inlineFastModelOverride": {
          "type": "string",
          "default": "",
          "description": "Optional model override used only for inline suggestions to prioritize speed. Leave empty to use provider-specific fast defaults."
        },
        "devpilot.enabledTools": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "create_directory",
            "create_file",
            "edit_file",
            "write_file",
            "replace_in_file",
            "rename_file"
          ],
          "description": "Enabled Devpilot agent tools for chat sessions. Use Devpilot: Configure Tools to manage this list."
        },
        "devpilot.provider": {
          "type": "string",
          "default": "local",
          "enum": [
            "local",
            "openai",
            "anthropic",
            "groq",
            "openrouter",
            "ollama"
          ],
          "description": "LLM provider used for chat and command workflows."
        },
        "devpilot.chatMode": {
          "type": "string",
          "default": "chat",
          "enum": [
            "chat",
            "agent",
            "plan"
          ],
          "description": "Default mode for Devpilot chat: chat for direct answers, agent for action-oriented execution guidance, and plan for step-by-step planning."
        },
        "devpilot.autoAttachCurrentFile": {
          "type": "boolean",
          "default": true,
          "description": "Automatically include the active editor file as extra context in chat prompts."
        },
        "devpilot.agentAllowFileWrites": {
          "type": "boolean",
          "default": false,
          "description": "Allow agent mode to execute file-write tool actions after approval. Keep OFF unless you trust the model output."
        },
        "devpilot.endpoint": {
          "type": "string",
          "default": "",
          "description": "Optional custom Devpilot backend base URL or /chat URL. Leave empty to use local backend."
        },
        "devpilot.openaiBaseUrl": {
          "type": "string",
          "default": "https://api.openai.com/v1",
          "description": "Base URL for OpenAI-compatible providers when devpilot.provider is openai."
        },
        "devpilot.anthropicBaseUrl": {
          "type": "string",
          "default": "https://api.anthropic.com/v1",
          "description": "Base URL for Anthropic provider when devpilot.provider is anthropic."
        },
        "devpilot.groqBaseUrl": {
          "type": "string",
          "default": "https://api.groq.com/openai/v1",
          "description": "Base URL for Groq OpenAI-compatible provider when devpilot.provider is groq."
        },
        "devpilot.openrouterBaseUrl": {
          "type": "string",
          "default": "https://openrouter.ai/api/v1",
          "description": "Base URL for OpenRouter OpenAI-compatible provider when devpilot.provider is openrouter."
        },
        "devpilot.ollamaBaseUrl": {
          "type": "string",
          "default": "http://127.0.0.1:11434",
          "description": "Base URL for Ollama when devpilot.provider is ollama."
        },
        "devpilot.requestTimeoutMs": {
          "type": "number",
          "default": 20000,
          "minimum": 1000,
          "description": "Request timeout in milliseconds for chat and command API calls."
        },
        "devpilot.enableGuardrails": {
          "type": "boolean",
          "default": true,
          "description": "Enable prompt/context sanitization and basic secret redaction before requests."
        },
        "devpilot.inlineLlmEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Use configured LLM for inline suggestions with context-window prompts; local fallback remains active."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test:unit": "npm run compile && node --test tests/unit/commandUtils.test.cjs",
    "test:integration": "npm run compile && node --test tests/integration/chatBackend.test.cjs",
    "test": "npm run test:unit && npm run test:integration",
    "package:vsix": "npm run compile && npx @vscode/vsce package --allow-missing-repository"
  },
  "devDependencies": {
    "@types/node": "^20.16.5",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.6.0",
    "typescript": "^5.6.2"
  },
  "dependencies": {
    "openai": "^6.32.0",
    "playwright": "^1.53.1"
  }
}
