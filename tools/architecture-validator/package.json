{
  "name": "architecture-validator",
  "displayName": "Architecture Validator",
  "description": "Validates layer boundaries such as Controller -> Service -> Repository",
  "version": "0.0.1",
  "publisher": "internal-tools",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:architectureValidator.validate"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "architectureValidator.validate",
        "title": "Architecture Validator: Validate Layers"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.16.5",
    "@types/vscode": "^1.95.0",
    "typescript": "^5.6.2"
  }
}
