{
  "name": "tool-reception",
  "version": "0.0.1",
  "private": true,
  "description": "MCP reception tool that recommends the right internal tool for developer objectives",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p ./",
    "start": "node dist/index.js",
    "dev": "npm run build && npm run start",
    "check:docs-index": "node scripts/validate-docs-index.mjs",
    "check:catalog-sync": "node scripts/validate-catalog-sync.mjs",
    "smoke": "node scripts/smoke.mjs",
    "test:golden": "node scripts/golden.mjs",
    "sync:catalog": "node scripts/sync-catalog.mjs",
    "test": "npm run check:docs-index && npm run check:catalog-sync && npm run smoke && npm run test:golden",
    "install:repo": "node scripts/install-mcp-in-repo.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.0"
  },
  "devDependencies": {
    "@types/node": "^20.16.5",
    "typescript": "^5.6.2"
  }
}
