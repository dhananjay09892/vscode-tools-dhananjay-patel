{
  "defaultToolId": "tool-reception",
  "tools": {
    "code-architecture-toolkit": {
      "sourceSubPath": "tools/code-architecture-toolkit",
      "installSubPath": ".copilot-tools/code-architecture-toolkit",
      "kind": "mcp-server",
      "installCommand": "ci",
      "buildCommand": "build"
    },
    "architecture-validator": {
      "sourceSubPath": "tools/architecture-validator",
      "installSubPath": ".copilot-tools/architecture-validator",
